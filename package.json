{
  "name": "storm-live-addon",
  "private": true,
  "version": "0.1.0",
  "description": "Live trading add-on scaffold for Storm Trade (TypeScript monorepo).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b .",
    "clean": "tsc -b . --clean",
    "start:paper": "npm run start:paper --workspace apps/trader-bot",
    "start:live": "npm run start:live --workspace apps/trader-bot",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
